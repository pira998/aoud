{
  "name": "claude-mobile-bridge",
  "version": "1.0.0",
  "description": "Control Claude Code from your mobile phone - bridge server with PWA mobile client",
  "type": "module",
  "main": "server/dist/server/src/index.js",
  "bin": {
    "claude-bridge": "./bin/cli.js"
  },
  "scripts": {
    "dev": "npm run dev --workspace=server",
    "dev:mobile": "npm run dev --workspace=mobile",
    "build": "npm run build --workspace=server && npm run build --workspace=mobile",
    "build:server": "npm run build --workspace=server",
    "build:mobile": "npm run build --workspace=mobile",
    "start": "node server/dist/index.js",
    "postinstall": "npm run build || true"
  },
  "workspaces": [
    "server",
    "mobile"
  ],
  "files": [
    "bin",
    "server/dist",
    "server/src",
    "mobile/dist",
    "shared"
  ],
  "keywords": [
    "claude",
    "anthropic",
    "mobile",
    "bridge",
    "cli",
    "claude-code",
    "ai",
    "assistant"
  ],
  "author": "YOUR_NAME <your.email@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YOUR_USERNAME/claude-mobile-bridge.git"
  },
  "homepage": "https://github.com/YOUR_USERNAME/claude-mobile-bridge#readme",
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/claude-mobile-bridge/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "commander": "^12.1.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.0",
    "localtunnel": "^2.0.2",
    "@ngrok/ngrok": "^1.4.0",
    "qrcode-terminal": "^0.12.0",
    "qrcode": "^1.5.3",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  }
}
